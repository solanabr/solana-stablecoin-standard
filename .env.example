# Solana Stablecoin Standard — Environment Configuration
# Copy to .env and fill in your values

# ── Solana Connection ────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com

# ── Program IDs ──────────────────────────────────────────────────────────
SSS_PROGRAM_ID=
TRANSFER_HOOK_PROGRAM_ID=
ORACLE_PROGRAM_ID=

# ── Backend Server ───────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ── Database (Event Indexer) ─────────────────────────────────────────────
DATABASE_URL=postgresql://sss:sss_password@localhost:5432/sss_events
DB_PORT=5432

# ── Authority Keys ───────────────────────────────────────────────────────
# Path to the authority keypair for signing transactions
AUTHORITY_KEYPAIR_PATH=~/.config/solana/id.json

# ── Webhook Configuration ───────────────────────────────────────────────
WEBHOOK_URL=
WEBHOOK_SECRET=
WEBHOOK_RETRY_COUNT=3
WEBHOOK_RETRY_DELAY_MS=1000
