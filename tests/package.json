{
  "name": "@stbr/sss-tests",
  "version": "1.0.0",
  "description": "Integration and fuzz tests for Solana Stablecoin Standard",
  "private": true,
  "scripts": {
    "test": "npm run test:integration && npm run test:fuzz",
    "test:integration": "ts-mocha -p ./tsconfig.json -t 1000000 integration/**/*.test.ts",
    "test:sss1": "ts-mocha -p ./tsconfig.json -t 1000000 integration/sss1-flow.test.ts",
    "test:sss2": "ts-mocha -p ./tsconfig.json -t 1000000 integration/sss2-flow.test.ts",
    "test:fuzz": "echo 'Fuzz tests require Trident - see fuzz/README.md'"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.0",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.87.6",
    "bn.js": "^5.2.1"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.5",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "chai": "^4.4.1",
    "mocha": "^10.2.0",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.3.3"
  }
}
