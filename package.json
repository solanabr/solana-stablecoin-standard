{
  "name": "solana-stablecoin-standard",
  "private": true,
  "version": "0.1.0",
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/web",
    "sdk/generated-kit",
    "sdk/generated-web3js",
    "sdk/client"
  ],
  "scripts": {
    "bootstrap": "yarn install",
    "dev:web": "yarn workspace @stbr/sss-web dev",
    "build:web": "yarn workspace @stbr/sss-web build",
    "lint:web": "yarn workspace @stbr/sss-web lint",
    "test:web": "yarn workspace @stbr/sss-web test",
    "generate": "node scripts/generate-sdks.mjs && node scripts/patch-generated.mjs",
    "build": "./scripts/build.sh",
    "build:ts": "tsc -b sdk/generated-kit sdk/generated-web3js sdk/client",
    "build:rust": "cargo check --workspace",
    "build:anchor": "anchor build",
    "verify": "./scripts/check.sh",
    "test:devnet:deploy": "./scripts/deploy-devnet.sh",
    "test:devnet": "mocha --require tsx/cjs --file tests/devnet/mocha.setup.ts \"tests/devnet/**/*.spec.ts\"",
    "test:devnet:stress": "mocha --require tsx/cjs --file tests/devnet/mocha.setup.ts \"tests/devnet/stress.spec.ts\"",
    "test:litesvm": "cargo test -p sss-litesvm-tests"
  },
  "devDependencies": {
    "@stbr/sss-client": "0.0.0",
    "@stbr/sss-generated-web3js": "0.0.0",
    "@codama/nodes-from-anchor": "^1.3.9",
    "@codama/renderers-js": "^2.0.3",
    "@codama/renderers-rust": "^3.0.0",
    "@coral-xyz/anchor": "^0.32.1",
    "@pratikbuilds/web3js-legacy": "^0.1.2",
    "codama": "^1.4.4",
    "@solana/kit": "^2.0.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.0",
    "mocha": "^11.1.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
