{
  "name": "@stbr/solana-stablecoin-standard",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.18.0",
  "description": "Solana Stablecoin Standard (SSS) — SDK, presets, and Token-2022 compliance modules for issuing stablecoins on Solana",
  "workspaces": [
    "sdk/*",
    "backend/*"
  ],
  "scripts": {
    "build": "pnpm -r --filter ./sdk/* build && pnpm -r --filter ./backend/* build",
    "test": "anchor test",
    "test:sdk": "pnpm -r --filter ./sdk/* test",
    "clean": "pnpm -r --filter ./sdk/* clean && pnpm -r --filter ./backend/* clean"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/spl-token": "^0.4.10",
    "@solana/web3.js": "^1.98.0"
  },
  "devDependencies": {
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.0",
    "chai": "^4.5.0",
    "mocha": "^10.8.2",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}

