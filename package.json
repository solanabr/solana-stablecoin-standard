{
  "name": "solana-stablecoin-standard",
  "version": "0.1.0",
  "private": true,
  "description": "Solana Stablecoin Standard — Modular SDK with standardized presets for Solana stablecoins",
  "license": "MIT",
  "scripts": {
    "dev": "turbo run dev --filter=@stbr/sss-backend --filter=@stbr/sss-frontend",
    "dev:all": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "test": "pnpm --filter tests test",
    "test:unit": "pnpm --filter tests test:unit",
    "test:integration": "pnpm --filter tests test:integration"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "tsx": "^4.7.0",
    "mocha": "^10.0.0",
    "chai": "^4.4.0",
    "@types/mocha": "^10.0.0",
    "@types/chai": "^4.3.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/web3.js": "^1.98.0",
    "@solana/spl-token": "^0.4.12"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.31.0"
}
