{
  "name": "solana-stablecoin-standard",
  "version": "0.1.0",
  "description": "Solana Stablecoin Standard - Superteam Brazil Bounty Submission",
  "scripts": {
    "build": "anchor build",
    "test": "anchor test",
    "test:sss-1": "anchor test -- --grep \"SSS-1\"",
    "test:sss-2": "anchor test -- --grep \"SSS-2\"",
    "deploy:devnet": "anchor deploy --provider.cluster devnet",
    "deploy:mainnet": "anchor deploy --provider.cluster mainnet",
    "lint": "eslint tests/**/*.ts",
    "format": "prettier --write tests/**/*.ts"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.0",
    "@types/bn.js": "^5.1.6",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "chai": "^4.5.0",
    "mocha": "^11.0.2",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
