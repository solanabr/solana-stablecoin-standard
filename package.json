{
  "name": "@stbr/solana-stablecoin-standard",
  "version": "0.1.0",
  "private": true,
  "description": "Solana Stablecoin Standard (SSS) — modular Token-2022 stablecoin SDK. SSS-1 (minimal) and SSS-2 (compliant) presets.",
  "workspaces": [
    "sdk/core",
    "cli"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -A run build",
    "test": "anchor test",
    "test:local": "anchor test --skip-local-validator",
    "test:sdk": "yarn workspaces foreach -A run test",
    "clean": "yarn workspaces foreach -A run clean",
    "lint": "eslint 'tests/**/*.ts' 'sdk/**/*.ts' 'cli/**/*.ts'"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/spl-token": "^0.4.10",
    "@solana/web3.js": "^1.98.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/chai": "^4.3.20",
    "@types/chai-as-promised": "^8.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "chai": "^4.5.0",
    "chai-as-promised": "^8.0.2",
    "mocha": "^10.8.2",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.7.3"
  }
}
