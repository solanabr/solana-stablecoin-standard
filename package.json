{
  "private": true,
  "license": "ISC",
  "workspaces": [
    "sdk",
    "services/shared",
    "services/indexer",
    "services/mint-burn",
    "services/webhook",
    "services/compliance"
  ],
  "scripts": {
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "test:anchor": "anchor test",
    "test:sdk": "yarn workspace @stbr/sss-token test",
    "test:cli": "cargo test -p sss-token --test cli_tests",
    "fuzz:trident": "trident run --manifest-path trident-tests/Trident.toml",
    "sdk:build": "yarn workspace @stbr/sss-token build",
    "sdk:clean": "yarn workspace @stbr/sss-token clean",
    "services:build": "yarn workspaces foreach --topological-dev --include '@sss/*' run build",
    "services:up": "docker compose -f services/docker-compose.yml up --build",
    "services:down": "docker compose -f services/docker-compose.yml down"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana-program/program-metadata": "^0.5.1",
    "@solana/spl-token": "^0.4.14"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.7.3"
  }
}
