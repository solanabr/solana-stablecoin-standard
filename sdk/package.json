{
  "name": "solana-stablecoin-sdk",
  "version": "0.1.2",
  "description": "Solana Stablecoin Standard — TypeScript SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./modules/compliance": {
      "types": "./dist/modules/compliance.d.ts",
      "default": "./dist/modules/compliance.js"
    },
    "./options": {
      "types": "./dist/options.d.ts",
      "default": "./dist/options.js"
    },
    "./presets": {
      "types": "./dist/presets/index.d.ts",
      "default": "./dist/presets/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "default": "./dist/utils/index.js"
    },
    "./idl/*": "./dist/idl/*",
    "./dist/idl/*": "./dist/idl/*"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc && cp -r src/idl dist/idl",
    "test": "ts-mocha -p tsconfig.json -t 1000000 src/**/*.test.ts",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["solana", "stablecoin", "token-2022", "anchor"],
  "license": "MIT",
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/web3.js": "^1.95.3",
    "@solana/spl-token": "^0.4.9",
    "bs58": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/mocha": "^10.0.0",
    "typescript": "^5.3.0",
    "ts-mocha": "^10.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  }
}